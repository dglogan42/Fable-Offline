# =============================================================================
# Fable 5 Offline Agent — .gitignore (Windows / macOS / Linux)
# https://github.com/dglogan42/Fable-Offline
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
.virtualenv/
.conda/

# Packaging / build
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/
*.manifest
*.spec
MANIFEST

# Test / lint / type / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.dmypy.json
pyrightconfig.json
.python-version

# Pip / install noise
pip-log.txt
pip-delete-this-directory.txt

# --- Secrets & local env ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.jks
credentials.json
secrets/
.secrets/
*.token
*.secret
*secret*
!*secret*.md.example
api_keys.*
**/id_rsa
**/id_ed25519
*.openai
*.anthropic

# --- IDE / editor ---
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace
.fleet/

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.Spotlight-V100
.Trashes

# OneDrive / sync junk (Windows)
~$*
*.tmp
*.temp

# --- Logs & scratch ---
*.log
logs/
tmp/
temp/
.cache/
*.bak
*.orig
*.old

# Jupyter
.ipynb_checkpoints/

# --- Local models & third-party agent state ---
*.gguf
*.bin
*.safetensors
models/
.openclaw/
.ollama/

# --- Fable 5 runtime (machine-local; do not commit) ---
# Loop memory, cycle logs, lessons, HITL/build/automate/self-improve logs, LOOP_STATE
memory/*
!memory/.gitkeep

# Build + team outputs (keep directory placeholder)
workspace/*
!workspace/.gitkeep

# Skills: ship shared seeds; ignore local drafts / sandboxes
skills/*.draft.md
skills/_local/
skills/**/__pycache__/

# User-only private workflows (seeded public recipes stay tracked)
workflows/_local/

# Knowledge: keep curated .md; ignore bulky raw scrapes + private matter files
knowledge/**/*.html
knowledge/**/*-raw.html
knowledge/**/*-raw.txt
knowledge/**/scrape-*.html
knowledge/**/scrape-*.md
knowledge/**/scrape-*.txt
knowledge/**/*.pdf
knowledge/**/*.docx
knowledge/legal/_local/
knowledge/legal/matters/
knowledge/legal/**/*confidential*
knowledge/brokers/_local/
knowledge/education/_local/
knowledge/education/**/*-raw*.txt
knowledge/education/lpu-raw-*.txt
knowledge/privacy/_local/
knowledge/urban-planning/_local/
# Dropped empty AEM clientlib stubs / forensic JS dumps (keep curated .md only)
clientlib-dependencies*.js
*.lc-d41d8cd98f00b204e9800998ecf8427e-lc.min.js

# Optional private soul / program overrides (defaults stay in repo)
SOUL.local.md
soul.local.md
program.local.md

# Optional local overrides (defaults stay in repo)
local_config.py
local_config.json
.fable5.local.*
config.local.*
