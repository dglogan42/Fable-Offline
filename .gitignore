# =============================================================================
# Fable 5 Offline Agent — .gitignore (Windows / macOS / Linux)
# https://github.com/dglogan42/Fable-Offline
#
# Ship curated markdown skills/knowledge/workflows only.
# Keep out: secrets, runtime memory/workspace, scrapes, PDFs, private .ics,
# Zoom/Google calendar credentials, Windows product keys, macOS recovery keys /
# full Installer apps / IPSW, social chat/snap exports, private RSS URLs with
# tokens, stream keys, Adobe passwords, heavy creative inbox/exports, soak dumps.
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
.virtualenv/
.conda/

# Packaging / build
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/
*.manifest
*.spec
MANIFEST

# Test / lint / type / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.dmypy.json
pyrightconfig.json
.python-version

# Pip / install noise
pip-log.txt
pip-delete-this-directory.txt

# --- Secrets & local env ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.jks
credentials.json
secrets/
.secrets/
*.token
*.secret
*secret*
!*secret*.md.example
api_keys.*
**/id_rsa
**/id_ed25519
*.openai
*.anthropic
# Browser-exposed keys sometimes pasted into dumps — keep out of commits
*maps*api*key*
# Prefer curated privacy notes; never commit live form posts
**/private-data/

# --- IDE / editor ---
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace
.fleet/

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.Spotlight-V100
.Trashes

# OneDrive / sync junk (Windows)
~$*
*.tmp
*.temp

# --- Logs & scratch ---
*.log
logs/
tmp/
temp/
.cache/
*.bak
*.orig
*.old

# Jupyter
.ipynb_checkpoints/

# --- Local models & third-party agent state ---
*.gguf
*.bin
*.safetensors
models/
.openclaw/
.ollama/

# --- Fable 5 runtime (machine-local; do not commit) ---
memory/*
!memory/.gitkeep
workspace/*
!workspace/.gitkeep

# Skills / workflows / agents: ship shared seeds; ignore local sandboxes
skills/*.draft.md
skills/_local/
skills/**/__pycache__/
scripts/**/__pycache__/
agents/_local/
agents/*.local.md
workflows/_local/
workflows/*.local.json

# Soak / perf scratch (local measurements; do not commit machine-specific dumps)
*.soak.json
*.soak.log
soak-results/
perf-results/

# --- Knowledge data policy ---
# Ship curated *.md only. Ignore scrapes, binaries, private matter.
knowledge/**/*.html
knowledge/**/*-raw.html
knowledge/**/*-raw.txt
knowledge/**/scrape-*.html
knowledge/**/scrape-*.md
knowledge/**/scrape-*.txt
knowledge/**/*.pdf
knowledge/**/*.docx
knowledge/**/*.xlsx
knowledge/**/*.csv
knowledge/**/_local/
knowledge/**/matters/
knowledge/**/*confidential*
knowledge/**/*-raw*.txt
knowledge/brokers/_local/
knowledge/education/_local/
knowledge/education/lpu-raw-*.txt
knowledge/legal/_local/
knowledge/legal/matters/
knowledge/privacy/_local/
knowledge/urban-planning/_local/
knowledge/pdf/_local/
knowledge/climate/_local/
knowledge/trade/_local/
knowledge/culture/_local/
knowledge/aem/_local/
knowledge/health/_local/
knowledge/public-safety/_local/
knowledge/property/_local/
knowledge/animals/_local/
knowledge/steam/_local/
knowledge/steam/*-local*.md
knowledge/steam/appids.local.*
knowledge/calendar/_local/
knowledge/calendar/*-local*.md
knowledge/calendar/*secret*
knowledge/calendar/*passcode*
knowledge/calendar/*meeting-id*
knowledge/windows/_local/
knowledge/windows/*-local*.md
knowledge/windows/*product*key*
knowledge/windows/*ProductKey*
knowledge/macos/_local/
knowledge/macos/*-local*.md
knowledge/macos/*recovery*key*
knowledge/macos/*FileVault*
knowledge/macos/*apple*id*
knowledge/social/_local/
knowledge/social/*-local*.md
# Personal photo dumps / private drafts (keep curated playbook)
knowledge/social/photos/
knowledge/social/drafts/
knowledge/social/*snap*export*
knowledge/social/*chat*export*
# Private / tokenized feed endpoints (public feed.xml demos OK under workspace/)
**/feed.private.xml
**/*rss*token*
knowledge/social/**/*.jpg
knowledge/social/**/*.jpeg
knowledge/social/**/*.png
knowledge/social/**/*.heic
knowledge/social/**/*.webp
knowledge/fashion/_local/
knowledge/fashion/*-local*.md
knowledge/fashion/**/*measure*
knowledge/conservation/_local/
knowledge/conservation/*-local*.md
knowledge/conservation/*-raw*
knowledge/ads/_local/
knowledge/ads/*-local*.md
knowledge/ads/*pixel*id*
knowledge/ads/*secret*
knowledge/media/_local/
knowledge/media/*-local*.md
knowledge/media/*stream*key*
**/*stream*key*
# Heavy media masters (export packages stay local)
workspace/creative/**/00_inbox/**
workspace/creative/**/01_selects/**
workspace/creative/**/04_exports/**
workspace/creative/**/*.psd
workspace/creative/**/*.psb
workspace/creative/**/*.dng
workspace/creative/**/*.cr2
workspace/creative/**/*.cr3
workspace/creative/**/*.nef
workspace/creative/**/*.arw
workspace/creative/**/*.mov
workspace/creative/**/*.mp4
workspace/creative/**/*.mxf
workspace/creative/**/*.drp
workspace/creative/**/*.prproj
!workspace/creative/**/notes.md
!workspace/creative/**/05_presets/**/*.md

# Math/physics lesson drafts may live under workspace/lessons (allowed)
# Keep private homework solutions out of public commits if sensitive:
knowledge/math/_local/
knowledge/physics/_local/
# Seamly / pattern CAD client files
**/*.sm2d
**/*.sm2d*
**/seamly-projects/
# Do not commit full macOS Installer apps, raw USB dumps, or firmware images
**/Install macOS *.app/**
**/Install OS X *.app/**
**/*.ipsw
**/*createinstallmedia*log*
# Private calendar exports / invites / Zoom join material
**/*.ics
!**/*.ics.example
!knowledge/calendar/**/*.ics.example
*.zoom.json
zoom-join*.txt

# PDFs and dumped PDF.js viewer bundles (curated knowledge/pdf notes only)
*.pdf
pdf.mjs
pdf.min.js
pdf.worker*.js
**/pdfjs*.js
!scripts/pdf_extract.py

# Empty AEM clientlib stubs / forensic JS dumps
clientlib-dependencies*.js
*.lc-d41d8cd98f00b204e9800998ecf8427e-lc.min.js
**/etc.clientlibs/**

# Optional private soul / program / config overrides
SOUL.local.md
soul.local.md
program.local.md
local_config.py
local_config.json
.fable5.local.*
config.local.*
