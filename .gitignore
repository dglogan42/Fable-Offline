# =============================================================================
# Fable 5 Offline Agent — .gitignore (Windows / macOS / Linux)
# https://github.com/dglogan42/Fable-Offline
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
.virtualenv/
.conda/

# Packaging / build
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/
*.manifest
*.spec
MANIFEST

# Test / lint / type / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.dmypy.json
pyrightconfig.json
.python-version

# Pip / install noise
pip-log.txt
pip-delete-this-directory.txt

# --- Secrets & local env ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets/
.secrets/
*.token

# --- IDE / editor ---
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace
.fleet/

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.Spotlight-V100
.Trashes

# OneDrive / sync junk (Windows)
~$*
*.tmp
*.temp

# --- Logs & scratch ---
*.log
logs/
tmp/
temp/
.cache/
*.bak
*.orig
*.old

# Jupyter
.ipynb_checkpoints/

# --- Local models & third-party agent state ---
*.gguf
*.bin
*.safetensors
models/
.openclaw/
.ollama/

# --- Fable 5 runtime (machine-local; do not commit) ---
# Loop memory, cycle logs, lessons, self-improve / build / automate logs
memory/*
!memory/.gitkeep

# Build outputs under workspace/ (keep directory placeholder)
workspace/*
!workspace/.gitkeep

# Skills: ship shared seeds; ignore local drafts / sandboxes
skills/*.draft.md
skills/_local/
skills/**/__pycache__/

# User-only private workflows (seeded public recipes stay tracked)
workflows/_local/

# Optional private soul override (default SOUL.md stays in repo)
SOUL.local.md
soul.local.md

# Optional local overrides (defaults stay in repo)
local_config.py
local_config.json
.fable5.local.*
